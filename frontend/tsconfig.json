{
  // Visit https://aka.ms/tsconfig to read more about this file
 
  "compilerOptions": {
    "target": "ES6",            // Gera código JS moderno [cite: 2026-03-05]
    "module": "ES6",            // Usa import/export nativo do navegador [cite: 2026-03-05]
    "outDir": "./dist",         // Joga os arquivos compilados na pasta dist [cite: 2026-03-10]
    "rootDir": "./src",         // Onde estão seus arquivos .ts originais [cite: 2026-03-10]
    "strict": true,             // Ativa a checagem rigorosa de tipos [cite: 2026-03-05]
    "skipLibCheck": true        // Evita conflitos com bibliotecas externas [cite: 2026-03-05]
  
}
}
